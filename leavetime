def compute_departure(bike_minutes, sbahn_delay, rain_start):
    now = datetime.now()

    # If rain starts soon, prefer S-Bahn
    if rain_start and rain_start < now + timedelta(minutes=bike_minutes):
        mode = "sbahn"
        leave = now + timedelta(minutes=sbahn_delay)
    else:
        mode = "bike"
        leave = now

    return mode, leave
